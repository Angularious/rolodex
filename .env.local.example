# ---- Orthogonal (required for live data) ----
# Server-side only. Never expose to the client.
ORTHOGONAL_API_KEY=

# ---- Cloudflare Turnstile (optional in dev; required in prod) ----
# If TURNSTILE_SECRET_KEY is unset, bot verification is skipped (dev mode).
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ---- Upstash Redis (optional in dev) ----
# If unset, the app falls back to an in-memory store (single-instance only).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Spend cap (editable) ----
# Daily global spend cap in USD. Kill switch trips at 100%, warns at 80%.
DAILY_SPEND_CAP_USD=20

# ---- Admin dashboard ----
# Password to access /admin (sent as ?key= or Authorization header).
ADMIN_PASSWORD=

# ---- Misc ----
# Salt for hashing visitor IPs in analytics (set any random string).
IP_HASH_SALT=change-me
