# ---- Orthogonal (required for live data) ----
# Server-side only. Never expose to the client.
ORTHOGONAL_API_KEY=

# ---- Origin lock (optional) ----
# /api/search rejects cross-origin POSTs. By default it allows requests whose
# Origin matches the serving host; set this to pin an explicit allowed origin
# (e.g. https://rolodex-lime.vercel.app) if you serve under a different host.
ALLOWED_ORIGIN=

# ---- Supabase (optional in dev; required in prod) ----
# Holds rate-limit + spend counters across Vercel's stateless instances.
# Run supabase/schema.sql once in the Supabase SQL editor. Server-side only.
# If unset, rate limits + spend cap are disabled (dev mode).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Spend cap (editable) ----
# Daily global spend cap in USD. Kill switch trips at 100%, warns at 80%.
DAILY_SPEND_CAP_USD=20

# ---- Site id (shared Supabase project) ----
# This Supabase project is shared with other Orthogonal demo sites. SITE_ID
# scopes this site's spend cap + analytics to its own rows so a busy sibling
# can't trip our cap or pollute /admin. Defaults to 'rolodex'; only set this if
# you deploy a copy under a different identity.
SITE_ID=rolodex

# ---- Admin dashboard ----
# Password to access /admin (Authorization: Bearer <password> header).
ADMIN_PASSWORD=

# ---- Cron (optional) ----
# Protects the daily keep-alive cron (/api/cron/keepalive) that stops Supabase's
# free tier from pausing after 7 days idle. Vercel auto-sends this as a Bearer
# token to scheduled cron requests. If unset, the endpoint is unprotected (fine,
# it only does a trivial read).
CRON_SECRET=

# ---- Misc ----
# Salt for hashing visitor IPs in analytics (set any random string).
IP_HASH_SALT=change-me
